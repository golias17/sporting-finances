{
  "name": "sporting-finances",
  "version": "1.0.0",
  "description": "An interactive, high-fidelity single-page application dashboard tracing the financial evolution of **Sporting Clube de Portugal - Futebol, SAD** over the last 13 fiscal years.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "clean:all": "npm run clean && rm -rf node_modules && rm -rf coverage",
    "build": "vite build --base=./",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "sporting-cp",
    "finance",
    "dashboard",
    "vite",
    "chartjs",
    "pwa"
  ],
  "author": "Guilherme Lima",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^27.4.0",
    "prettier": "^3.9.5",
    "vite": "^8.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8"
  }
}
