# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#testing)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp's build directory (https://github.com/nodejs/node-gyp#path-options)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rts2_cache_compile
.rts2_cache_errors

# Optional REPL history
.node_repl_history

# Output directory (Vite build)
dist/
# Ad-hoc build-verification output dirs used during development (vite build
# --outDir dist_checkN) — a sandbox quirk made the default dist/ name
# occasionally non-reusable, so each verification run used a fresh numbered
# name instead. Never meant to be committed.
dist_check*/
# Scratch test files renamed out of the *.test.js glob (so vitest skips
# them) while reproducing a bug, then left in place rather than deleted.
*.bak

# Editor files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables
.env
.env.*

